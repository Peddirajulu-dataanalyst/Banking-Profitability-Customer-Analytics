      <aliases enabled='yes' />
      <column caption='rank' datatype='integer' name='[Calculation_1154799086014470]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([total_revenue]),&apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top 5% Customers' datatype='real' name='[Calculation_1154799086862343]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(COUNTD([customer_id])* 0.05,0)' />
      </column>
      <column caption='Top Customers flag' datatype='integer' name='[Calculation_1154799087497224]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1154799086014470] &lt;= [Calculation_1154799086862343] THEN 1 ELSE 0 END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top 5% Revenue Contribution ' datatype='real' name='[Calculation_1154799094890505]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_SUM(IF [Calculation_1154799087497224] = 1 THEN SUM([total_revenue]) END)/WINDOW_SUM(SUM([total_revenue]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Dynamic Revenue Segment' datatype='string' name='[Calculation_1485755652448256]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([total_revenue]) &gt;= WINDOW_PERCENTILE(sum([total_revenue]),0.80) THEN &quot;Top 20%&quot; ELSE &quot;Bottom 80%&quot; END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='total_default_whole' datatype='integer' name='[Calculation_1717473865306115]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT([total_defaults])' />
      </column>
      <column caption='Total Revenue Measure' datatype='real' name='[Calculation_1717473876369412]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_revenue])' />
      </column>
      <column caption='Avg Days Late Measure' datatype='real' name='[Calculation_1717473877000197]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([avg_days_late])' />
      </column>
      <column caption='Avg_Default Rate' datatype='real' name='[Calculation_1717473877348358]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([Calculation_1717473865306115])/COUNT([customer_id])' />
      </column>
      <column caption='High Risk %' datatype='real' name='[Calculation_1717473877745671]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum(IF [risk_segment] = &quot;High Risk&quot; THEN 1 ELSE 0 END)/count([customer_id])' />
      </column>
      <column caption='Early Warning Customers' datatype='integer' name='[Calculation_1717473878368264]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([early_warning])' />
      </column>
      <column caption='revenue_data.csv' datatype='table' name='[__tableau_internal_object_id__].[revenue_data.csv_A3997CEE50134D18BA1E3112383767B4]' role='measure' type='quantitative' />
