        </calculation>
      </column>
      <column caption='Top 5% Revenue Contribution ' datatype='real' name='[Calculation_1154799094890505]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_SUM(IF [Calculation_1154799087497224] = 1 THEN SUM([total_revenue]) END)/WINDOW_SUM(SUM([total_revenue]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
