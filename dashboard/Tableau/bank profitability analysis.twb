      </column>
      <column caption='Default Rate' datatype='real' name='[Calculation_1717473877348358]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([Calculation_1717473865306115])/COUNT([customer_id])' />
      </column>
      <column caption='High Risk %' datatype='real' name='[Calculation_1717473877745671]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum(IF [risk_segment] = &quot;High Risk&quot; THEN 1 ELSE 0 END)/count([customer_id])' />
